# Supabase (optional) — powers the Daily Winners panel with finished-round results.
# When unset, the app still runs and Daily Winners shows its "revealed after the round ends"
# fallback. The anon key is safe to expose in the browser (read-only public data).
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY
